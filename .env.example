# NestMatch — Variables de entorno
# Copia este archivo como .env y rellena los valores

# ── Base de datos (Railway te da esto automáticamente) ──
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nestmatch

# ── JWT ──
JWT_SECRET=cambia_esto_por_un_string_muy_largo_y_seguro_min_32_chars

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...          # o sk_test_... para pruebas
STRIPE_PUBLISHABLE_KEY=pk_live_...    # o pk_test_... para pruebas
STRIPE_PRICE_ID=price_...             # ID del precio mensual en Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...       # Obtenido al crear el webhook en Stripe

# ── App ──
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://tu-app.railway.app

# ── Email (Resend) ──
# 1. Crea una cuenta gratis en https://resend.com
# 2. Ve a API Keys y crea una nueva
# 3. (Opcional) Verifica tu dominio en Resend para enviar desde tu propio email
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=NestMatch <onboarding@resend.dev>

# ── Opcional: Cloudinary para fotos (recomendado) ──
# CLOUDINARY_URL=cloudinary://...
